---
import '../styles/global.css';
const year = new Date().getFullYear();
const assetVersion = '2026-05-24';
const canonicalUrl = 'https://guardianwarriors.org/';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#08152a" />
    <title>Guardian Warriors Foundation | Community Protection & Family Advocacy</title>
    <meta
      name="description"
      content="Guardian Warriors Foundation advances child safety, family resilience, and community advocacy through education, outreach, and trauma-informed support."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta property="og:image" content="https://guardianwarriors.org/favicon.svg" />
    <meta name="twitter:image" content="https://guardianwarriors.org/favicon.svg" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <header class="site-header">
      <div class="container nav-wrap">
        <a class="brand" href="#top" aria-label="Guardian Warriors homepage">
          <img class="brand-mark" src={`/brand-mark.svg?v=${assetVersion}`} alt="" aria-hidden="true" />
          <span>Guardian Warriors</span>
        </a>
        <nav aria-label="Primary navigation">
          <a href="#mission">Mission</a>
          <a href="#programs">Programs</a>
          <a href="#stories">Stories</a>
          <a href="#impact">Impact</a>
          <a href="#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <section id="top" class="hero" aria-labelledby="hero-title">
        <div class="hero-overlay"></div>
        <div class="container hero-grid">
          <div class="hero-copy">
            <p class="kicker">Guardian Warriors Foundation</p>
            <h1 id="hero-title">Protecting children. Strengthening families. Mobilizing communities.</h1>
            <p>
              We help families navigate crisis, build long-term stability, and connect with compassionate
              local partners who are committed to child safety.
            </p>
            <div class="hero-actions">
              <a class="btn" href="#contact">Become a Supporter</a>
              <a class="btn btn-outline" href="#programs">Explore Programs</a>
            </div>
          </div>
          <img src={`/about.jpg?v=${assetVersion}`} alt="Guardian Warriors staff supporting families in the community" loading="eager" />
        </div>
      </section>

      <section id="mission" class="section">
        <div class="container split">
          <div>
            <p class="kicker">Our Mission</p>
            <h2>Safe homes and hopeful futures for every child.</h2>
            <p>
              Guardian Warriors exists to reduce harm, restore confidence, and equip caregivers with practical
              tools. Our services combine prevention training, emergency assistance, and mentorship designed for
              sustainable outcomes.
            </p>
          </div>
          <img src={`/services.jpg?v=${assetVersion}`} alt="Community members collaborating around a table" loading="lazy" />
        </div>
      </section>

      <section id="programs" class="section alt">
        <div class="container">
          <p class="kicker">What We Do</p>
          <h2>Programs designed for real-world family needs.</h2>
          <div class="cards">
            <article>
              <h3>Prevention Education</h3>
              <p>Workshops for youth, schools, and caregivers focused on awareness, boundaries, and response planning.</p>
            </article>
            <article>
              <h3>Crisis Stabilization</h3>
              <p>Rapid referrals, safety planning, and direct support for families facing immediate challenges.</p>
            </article>
            <article>
              <h3>Mentorship & Recovery</h3>
              <p>Trauma-informed mentoring, parent support groups, and resilience-centered healing resources.</p>
            </article>
          </div>
        </div>
      </section>

      <section id="stories" class="section gallery-section">
        <div class="container">
          <p class="kicker">In the Community</p>
          <h2>Driven by people, powered by partnership.</h2>
          <div class="gallery">
            <img src={`/transformation.jpg?v=${assetVersion}`} alt="Volunteers at community outreach event" loading="lazy" />
            <img src={`/changelives.jpg?v=${assetVersion}`} alt="Mentorship activity with youth participants" loading="lazy" />
            <img src={`/leadership.jpg?v=${assetVersion}`} alt="Family services and support session" loading="lazy" />
            <img src={`/nextsteps.jpg?v=${assetVersion}`} alt="Guardian Warriors partner collaboration" loading="lazy" />
          </div>
        </div>
      </section>

      <section id="impact" class="section alt">
        <div class="container stats">
          <div><strong>2,500+</strong><span>Families reached each year</span></div>
          <div><strong>40+</strong><span>Local and regional partners</span></div>
          <div><strong>85%</strong><span>Program completion rate</span></div>
          <div><strong>300+</strong><span>Volunteer advocates mobilized</span></div>
        </div>
      </section>

      <section id="contact" class="section">
        <div class="container contact-card">
          <p class="kicker">Get Involved</p>
          <h2>Join the Guardian Warriors network.</h2>
          <p>Whether you donate, volunteer, or become a community partner, your action helps protect children and support families.</p>
          <div class="contact-grid">
            <p><strong>Email:</strong> hello@guardianwarriors.org</p>
            <p><strong>Phone:</strong> (813) 317-8655</p>
          </div>
          <a class="btn" href="mailto:hello@guardianwarriors.org">Contact the Foundation</a>
        </div>
      </section>
    </main>

    <footer>
      <div class="container">© {year} Guardian Warriors Foundation. All rights reserved.</div>
    </footer>
  </body>
</html>
