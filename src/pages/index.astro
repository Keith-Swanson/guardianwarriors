---
import BaseHead from '../components/BaseHead.astro';
import GuardianWarriorsSite from '../components/GuardianWarriorsSite.jsx';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style is:global>
			/* Defensive override to ensure the landing page never inherits narrow blog container widths */
			main.gw-main {
				width: 100% !important;
				max-width: none !important;
				margin: 0 !important;
				padding: 0 !important;
			}
		</style>
	</head>
	<body>
		<GuardianWarriorsSite client:load />
	</body>
</html>
